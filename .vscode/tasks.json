{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "setup: worktree (data-shared)",
            "type": "shell",
            "command": "./scripts/setup-worktree.sh",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            }
        },
        {
            "label": "setup: worktree (data-local)",
            "type": "shell",
            "command": "./scripts/setup-worktree.sh --data-local",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            }
        },
        {
            "label": "Paper: compile",
            "type": "shell",
            "command": "bash notes/assets/publish/scripts/compile_paper.sh",
            "problemMatcher": []
        },
        {
            "label": "Pandoc: quick-pdf",
            "type": "shell",
            "command": "cd ./notes && pandoc -F mermaid-filter -s ${file} -o ${fileDirname}/assets/pdf-output/${fileBasenameNoExtension}.pdf --pdf-engine=xelatex -V geometry:'top=2cm, bottom=1.5cm, left=2cm, right=2cm' --strip-comments  && cd ..",
            "problemMatcher": []
        },
        {
            "label": "Pandoc: quick-landscape-pdf",
            "type": "shell",
            "command": "cd ./notes && pandoc -F mermaid-filter -s ${file} -o ${fileDirname}/assets/pdf-output/${fileBasenameNoExtension}.pdf --pdf-engine=xelatex -V geometry:'top=0.1cm, bottom=0.1cm, left=0.1cm, right=0.1cm,landscape' --strip-comments   && cd ..",
            "problemMatcher": []
        },
        {
            "label": "Pandoc: bib-pdf",
            "type": "shell",
            "command": "cd ./notes && pandoc -F mermaid-filter -s ${file} -o ${fileDirname}/assets/pdf-output/${fileBasenameNoExtension}.pdf --pdf-engine=xelatex --citeproc --bibliography assets/publish/bib/bib.bib --metadata csl=assets/publish/bib/nature.csl -V geometry:'top=2cm, bottom=1.5cm, left=2cm, right=2cm' --strip-comments  && cd ..",
            "problemMatcher": []
        },
        {
            "label": "Pandoc: bib-tex-pdf",
            "type": "shell",
            "command": "./notes/assets/publish/scripts/bib_tex_pdf.sh ${file} ${fileDirname} ${fileBasenameNoExtension}",
            "problemMatcher": []
        },
        {
            "label": "Pandoc: bib-tex-pdf-landscape",
            "type": "shell",
            "command": "./notes/assets/publish/scripts/bib_tex_pdf_landscape.sh ${file} ${fileDirname} ${fileBasenameNoExtension}",
            "problemMatcher": []
        },
        {
            "label": "Pandoc: bib-tex-docx",
            "type": "shell",
            "command": "./notes/assets/publish/scripts/bib_tex_docx.sh ${file} ${fileDirname} ${fileBasenameNoExtension}",
            "problemMatcher": []
        },
        {
            "label": "notability: sync",
            "type": "shell",
            "command": "bash notes/assets/scripts/notability_sync.sh",
            "problemMatcher": []
        },
        {
            "label": "black: file",
            "type": "shell",
            "command": "black",
            "args": [
                "${file}"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "isort: file",
            "type": "shell",
            "command": "isort ${file}",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "close": false
            }
        },
        {
            "label": "add frontmatter (py/sh)",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/notes/assets/scripts/add_frontmatter.py",
                "${file}"
            ],
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "move file [opens note & test] (py/sh)",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/notes/assets/scripts/move_file_with_related.py",
                "${file}",
                "${input:moveDestinationPath}"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always"
            }
        },
        {
            "label": "create test file (py lib only)",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/notes/assets/scripts/create_python_test_file.py",
                "create",
                "${file}"
            ],
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "delete file [opens note & test] (py/sh)",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/notes/assets/scripts/delete_file_and_open_related.py",
                "${file}"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            }
        },
        {
            "label": "open related code (from note) (py/sh)",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/notes/assets/scripts/from_note_open_related_file.py",
                "${file}"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "dendron: open random notes",
            "type": "shell",
            "command": "python notes/assets/scripts/open_random_notes.py -n ${input:openRandomNotes} -d ${workspaceFolder}/notes",
            "problemMatcher": []
        },
        {
            "label": "sphinx: apidoc",
            "type": "shell",
            "command": "sphinx-apidoc -f -o docs/source/generated Dendron-Template",
            "problemMatcher": []
        },
        {
            "label": "pytest: coverage",
            "type": "shell",
            "command": "pytest --cov=Dendron-Template --cov-report html tests/",
            "problemMatcher": []
        },
        {
            "label": "Open External Terminal",
            "type": "shell",
            "command": "./notes/assets/scripts/open-external-terminal.sh",
            "problemMatcher": []
        },
        {
            "label": "git: open all changed files",
            "type": "shell",
            "command": "code $(git status -uall --porcelain | awk '{print $NF}')",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ],
    "inputs": [
        {
            "id": "openRandomNotes",
            "description": "number of random notes to open",
            "type": "pickString",
            "options": [
                "1",
                "2",
                "4",
                "8",
                "16"
            ]
        },
        {
            "id": "moveDestinationPath",
            "type": "promptString",
            "description": "Enter destination path for move/rename:"
        }
    ]
}
